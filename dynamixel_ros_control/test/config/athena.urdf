  <ros2_control name="athena_arm_interface" type="system">
    <hardware>
      <plugin>dynamixel_ros_control/DynamixelHardwareInterface</plugin>
      <param name="debug">false</param>
      <param name="port_name">/dev/ttyUSB_manipulator_arm</param>
      <param name="baud_rate">1000000</param>
      <param name="use_dummy">true</param>
      <param name="torque_on_startup">true</param>
      <param name="torque_off_on_shutdown">false</param>
    </hardware>
    <joint name="arm_joint_1">
      <param name="id">11</param>
      <param name="registers.homing_offset">0.0</param>
      <param name="registers.led_blue">255</param>
      <param name="position_control_mode">extended_position</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="current"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <transmission name="arm_joint_1_transmission">
      <plugin>transmission_interface/SimpleTransmission</plugin>
      <actuator name="arm_joint_1_actuator" role="arm_joint_1_actuator"/>
      <joint name="arm_joint_1" role="arm_joint_1">
        <mechanical_reduction>1.0</mechanical_reduction>
        <offset>0.0</offset>
      </joint>
    </transmission>
    <joint name="arm_joint_2">
      <param name="id">12</param>
      <param name="registers.homing_offset">0.24434609527920614</param>
