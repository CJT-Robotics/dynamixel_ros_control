        <link>flipper_fr_link</link>
      </right_track>
      <right_track>
        <link>flipper_br_link</link>
      </right_track>
      <tracks_separation>1.0</tracks_separation>
      <tracks_height>0.215</tracks_height>
      <steering_efficiency>1.0</steering_efficiency>
      <linear_velocity>
        <min_velocity>-1.5</min_velocity>
        <max_velocity>1.5</max_velocity>
        <!--min_acceleration>100</min_acceleration>
        <max_acceleration></max_acceleration>
        <min_jerk></min_jerk>
        <max_jerk></max_jerk-->
      </linear_velocity>
