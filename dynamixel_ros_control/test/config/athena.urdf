      <update_rate>30.0</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <gz_frame_id>gripper_joint_link_l2</gz_frame_id>
      <topic>/athena/force_torque_sensor/finger_l/wrench</topic>
      <force_torque name="finger">
