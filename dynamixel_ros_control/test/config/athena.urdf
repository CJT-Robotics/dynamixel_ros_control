  <ros2_control name="athena_flipper_interface" type="system">
    <hardware>
      <plugin>dynamixel_ros_control/DynamixelHardwareInterface</plugin>
      <param name="debug">false</param>
      <param name="port_name">/dev/ttyUSB_flippers</param>
      <param name="baud_rate">1000000</param>
      <param name="use_dummy">true</param>
      <param name="torque_on_startup">true</param>
      <param name="torque_off_on_shutdown">false</param>
    </hardware>
    <joint name="flipper_fl_joint">
      <param name="id">1</param>
      <!--<param name="registers.torque_limit">9.0</param>-->
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="current"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="current"/>
