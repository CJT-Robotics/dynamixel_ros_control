        <min_jerk></min_jerk>
        <max_jerk></max_jerk-->
      </angular_velocity>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>athena/cmd_vel_out</topic>
      <steering_efficiency_topic>athena/steering_efficiency</steering_efficiency_topic>
      <odom_topic>athena/odom_wheel</odom_topic>
      <!--       <tf_topic>$(arg robot_name)/tf</tf_topic> Do not publish to tf-->
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
