    <plugin filename="libgz-sim-tracked-vehicle-system" name="gz::sim::systems::TrackedVehicle">
      <!--https://gazebosim.org/api/sim/9/classgz_1_1sim_1_1systems_1_1TrackedVehicle.html-->
      <left_track>
        <link>main_track_left_link</link>
      </left_track>
      <left_track>
        <link>flipper_fl_link</link>
      </left_track>
      <left_track>
