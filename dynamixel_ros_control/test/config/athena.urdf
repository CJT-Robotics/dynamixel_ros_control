  <gazebo reference="gripper_rgb_link">
    <sensor name="gripper_rgb_camera_sensor" type="camera">
      <update_rate>30</update_rate>
      <topic>athena/gripper_rgb/image_raw</topic>
      <gz_frame_id>gripper_rgb_optical_frame</gz_frame_id>
      <camera name="gripper_rgb">
        <camera_info_topic>athena/gripper_rgb/camera_info</camera_info_topic>
        <horizontal_fov>1.085594794740473</horizontal_fov>
        <image>
          <format>R8G8B8</format>
          <width>1640</width>
          <height>1232</height>
        </image>
        <clip>
          <near>0.01</near>
          <far>100</far>
        </clip>
      </camera>
      <!--frameName>${name}_optical_frame</frameName-->
    </sensor>
  </gazebo>
  <gazebo reference="gripper_rgbd_link">
    <sensor name="gripper_rgbd_color" type="camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>15</update_rate>
      <topic>/athena/gripper_rgbd/color/image_raw</topic>
      <gz_frame_id>gripper_rgbd_color_frame</gz_frame_id>
      <camera name="gripper_rgbd_camera">
        <camera_info_topic>/athena/gripper_rgbd/color/camera_info</camera_info_topic>
        <optical_frame_id>gripper_rgbd_color_optical_frame</optical_frame_id>
        <horizontal_fov>1.0995574287564276</horizontal_fov>
        <vertical_fov>0.8726646259971648</vertical_fov>
        <image>
          <format>R8G8B8</format>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>10</far>
        </clip>
      </camera>
    </sensor>
    <!-- Depth Image of real camera is already registered to RGB image and has the same camera
      info -->
    <sensor name="gripper_rgbd_depth" type="depth_camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>15</update_rate>
      <topic>/athena/gripper_rgbd/depth/image_raw</topic>
      <gz_frame_id>gripper_rgbd_depth_frame</gz_frame_id>
      <camera>
        <camera_info_topic>/athena/gripper_rgbd/depth/camera_info</camera_info_topic>
        <optical_frame_id>gripper_rgbd_depth_optical_frame</optical_frame_id>
        <horizontal_fov>1.0995574287564276</horizontal_fov>
        <vertical_fov>0.8726646259971648</vertical_fov>
        <image>
          <format>R_FLOAT32</format>
          <width>640</width>
          <height>480</height>
        </image>
        <depth_camera>
          <clip>
            <near>0.15</near>
            <far>10.0</far>
          </clip>
        </depth_camera>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </camera>
    </sensor>
  </gazebo>
